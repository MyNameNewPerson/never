<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Neverlands.Mobile.Views.SettingsPage"
             Title="Settings">
    <VerticalStackLayout Padding="20" Spacing="15">
        <HorizontalStackLayout Spacing="10">
            <CheckBox IsChecked="{Binding AutoWoodcutting}" />
            <Label Text="Auto Woodcutting" VerticalOptions="Center"/>
        </HorizontalStackLayout>

        <HorizontalStackLayout Spacing="10">
            <CheckBox IsChecked="{Binding AutoCombat}" />
            <Label Text="Auto Combat" VerticalOptions="Center"/>
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>
