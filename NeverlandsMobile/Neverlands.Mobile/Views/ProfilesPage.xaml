<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Neverlands.Mobile.ViewModels"
             xmlns:models="clr-namespace:Neverlands.Core.Models;assembly=Neverlands.Core"
             x:Class="Neverlands.Mobile.Views.ProfilesPage"
             x:DataType="vm:ProfilesViewModel"
             Title="Профили">
    <Grid RowDefinitions="*, Auto" Padding="10">
        <CollectionView Grid.Row="0" ItemsSource="{Binding Profiles}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:UserProfile">
                    <Frame Margin="0,5" Padding="10">
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding Nickname}" FontSize="18" FontAttributes="Bold" />
                                <Label Text="Активный" IsVisible="{Binding IsActive}" TextColor="Green" />
                                <Label Text="{Binding LastLogin, StringFormat='Последний вход: {0:dd.MM.yyyy HH:mm}'}" FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>

                            <HorizontalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                <Button Text="Войти"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProfilesViewModel}}, Path=LoginCommand}"
                                        CommandParameter="{Binding .}" />
                                <Button Text="Удалить"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProfilesViewModel}}, Path=DeleteCommand}"
                                        CommandParameter="{Binding .}"
                                        TextColor="Red" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="1" Text="Добавить новый" Command="{Binding AddCommand}" Margin="0,10,0,0" />
    </Grid>
</ContentPage>
