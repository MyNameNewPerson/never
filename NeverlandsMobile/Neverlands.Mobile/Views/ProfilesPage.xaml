<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Neverlands.Mobile.Views.ProfilesPage"
             Title="Profiles">
    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Character Profiles" FontSize="24" HorizontalOptions="Center" />
        <CollectionView ItemsSource="{Binding Profiles}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="{Binding CharacterName}" FontAttributes="Bold" />
                            <Label Text="{Binding Level, StringFormat='Lvl {0}'}" />
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Button Text="Add New Profile" HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>
