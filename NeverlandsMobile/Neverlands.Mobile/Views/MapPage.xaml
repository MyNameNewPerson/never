<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Neverlands.Mobile.ViewModels"
             x:Class="Neverlands.Mobile.Views.MapPage"
             x:DataType="vm:MapViewModel"
             Title="Карта">
    <Grid RowDefinitions="*, Auto" Padding="10">
        <ScrollView Grid.Row="0" HorizontalOptions="Center" VerticalOptions="Center">
            <Grid x:Name="MapGrid"
                  RowSpacing="1"
                  ColumnSpacing="1"
                  BindableLayout.ItemsSource="{Binding Cells}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:MapCellViewModel">
                        <Button Text="{Binding Name}"
                                Grid.Row="{Binding Row}"
                                Grid.Column="{Binding Column}"
                                BackgroundColor="{Binding CellColor}"
                                FontSize="8"
                                Padding="1"
                                WidthRequest="40"
                                HeightRequest="40"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MapViewModel}}, Path=SelectCellCommand}"
                                CommandParameter="{Binding .}" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </Grid>
        </ScrollView>

        <VerticalStackLayout Grid.Row="1" Padding="10" Spacing="5" IsVisible="{Binding HasSelectedCell}">
            <Label Text="{Binding SelectedCellName}" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" />
            <Button Text="Перейти" Command="{Binding GoToCellCommand}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
