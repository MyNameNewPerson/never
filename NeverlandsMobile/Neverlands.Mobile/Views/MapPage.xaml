<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:Neverlands.Mobile.ViewModels"
             x:Class="Neverlands.Mobile.Views.MapPage"
             Title="Map">
    <VerticalStackLayout Padding="20" Spacing="10">
        <Label Text="World Map" FontSize="24" HorizontalOptions="Center" />
        <Label Text="{Binding CurrentLocation, StringFormat='Current Location: {0}'}" FontSize="18" />

        <CollectionView ItemsSource="{Binding NearbyCells}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5" Padding="10">
                        <Label Text="{Binding .}" />
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
