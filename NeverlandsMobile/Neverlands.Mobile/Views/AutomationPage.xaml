<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Neverlands.Mobile.ViewModels"
             x:Class="Neverlands.Mobile.Views.AutomationPage"
             x:DataType="vm:AutomationViewModel"
             Title="Автоматизация">
    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
        <Frame Grid.Row="0" Padding="15" Margin="0,0,0,15">
            <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                <Label Text="Общая автоматизация" VerticalOptions="Center" FontAttributes="Bold"/>
                <Switch IsToggled="{Binding IsAutomationEnabled}" />
            </HorizontalStackLayout>
        </Frame>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="15">
                <Label Text="Режимы работы" FontSize="18" FontAttributes="Bold"/>

                <Frame Padding="10">
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout>
                            <Label Text="Автобой" FontAttributes="Bold"/>
                            <Label Text="Автоматические сражения с монстрами" FontSize="12" TextColor="Gray"/>
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding IsAutoCombatEnabled}" />
                    </Grid>
                </Frame>

                <Frame Padding="10">
                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout>
                            <Label Text="Сбор ресурсов" FontAttributes="Bold"/>
                            <Label Text="Рыбалка, рубка леса, добыча руды" FontSize="12" TextColor="Gray"/>
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding IsResourceGatheringEnabled}" />
                    </Grid>
                </Frame>

                <Label Text="Доступные скрипты" FontSize="18" FontAttributes="Bold" Margin="0,10,0,0"/>
                <CollectionView ItemsSource="{Binding Scripts}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="10" Margin="0,2">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Text="{Binding Name}" VerticalOptions="Center"/>
                                    <Button Grid.Column="1" Text="Запуск" Scale="0.8"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AutomationViewModel}}, Path=RunScriptCommand}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <Frame Grid.Row="2" Padding="10" Margin="0,10,0,0" BorderColor="Gray">
            <VerticalStackLayout>
                <Label Text="Статус:" FontSize="12" TextColor="Gray"/>
                <Label Text="{Binding CurrentTaskStatus}" FontAttributes="Italic"/>
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>
