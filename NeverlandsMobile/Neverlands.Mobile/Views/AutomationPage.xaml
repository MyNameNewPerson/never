<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Neverlands.Mobile.ViewModels"
             xmlns:interfaces="clr-namespace:Neverlands.Core.Interfaces;assembly=Neverlands.Core"
             x:Class="Neverlands.Mobile.Views.AutomationPage"
             x:DataType="vm:AutomationViewModel"
             Title="Автоматизация">
    <Grid RowDefinitions="Auto, *, Auto, *" Padding="20" Spacing="10">

        <!-- Переключатели режимов -->
        <VerticalStackLayout Grid.Row="0" Spacing="10">
            <HorizontalStackLayout Spacing="10">
                <Switch IsToggled="{Binding IsAutomationRunning}" />
                <Label Text="Автоматизация" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <Switch IsToggled="{Binding IsResourceFarmingEnabled}" />
                <Label Text="Автосбор ресурсов" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <Switch IsToggled="{Binding IsAutoCombatEnabled}" />
                <Label Text="Автобой" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Список скриптов -->
        <VerticalStackLayout Grid.Row="1" Spacing="5">
            <Label Text="Скрипты" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding Scripts}" HeightRequest="150">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="interfaces:GameScript">
                        <Grid ColumnDefinitions="*, Auto" Padding="5">
                            <Label Text="{Binding Name}" VerticalOptions="Center" />
                            <Button Grid.Column="1" Text="Пуск"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AutomationViewModel}}, Path=RunScriptCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <!-- Текущая задача -->
        <VerticalStackLayout Grid.Row="2" Spacing="5">
            <Label Text="Текущая задача:" FontAttributes="Bold" />
            <Label Text="{Binding CurrentTaskDescription}" TextColor="Blue" />
            <Button Text="Остановить всё" Command="{Binding StopScriptCommand}" />
        </VerticalStackLayout>

        <!-- Лог автоматизации -->
        <VerticalStackLayout Grid.Row="3" Spacing="5">
            <Label Text="Лог автоматизации" FontAttributes="Bold" />
            <ScrollView x:Name="LogScroll">
                <Label Text="{Binding AutomationLog}" FontSize="12" />
            </ScrollView>
        </VerticalStackLayout>

    </Grid>
</ContentPage>
