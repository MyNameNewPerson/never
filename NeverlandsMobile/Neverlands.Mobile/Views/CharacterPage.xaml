<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Neverlands.Mobile.ViewModels"
             x:Class="Neverlands.Mobile.Views.CharacterPage"
             x:DataType="vm:CharacterViewModel"
             Title="Персонаж">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="{Binding Name}" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
            <Label Text="{Binding Level, StringFormat='Уровень {0}'}" FontSize="18" HorizontalOptions="Center" />

            <!-- Полоски состояния -->
            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding HpStatus, StringFormat='HP: {0}'}" />
                <ProgressBar Progress="{Binding HpPercent}" ProgressColor="Red" />

                <Label Text="{Binding MpStatus, StringFormat='MP: {0}'}" />
                <ProgressBar Progress="{Binding MpPercent}" ProgressColor="Blue" />

                <Label Text="{Binding ExpStatus, StringFormat='Опыт: {0}'}" />
                <ProgressBar Progress="{Binding ExpPercent}" ProgressColor="Green" />
            </VerticalStackLayout>

            <Label Text="{Binding Gold, StringFormat='Золото: {0}'}" FontSize="16" FontAttributes="Bold" />

            <!-- Характеристики -->
            <Frame Padding="10">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Характеристики" FontAttributes="Bold" Margin="0,0,0,5" />
                    <Label Text="{Binding Attack, StringFormat='Атака: {0}'}" />
                    <Label Text="{Binding Defense, StringFormat='Защита: {0}'}" />
                    <Label Text="{Binding Speed, StringFormat='Скорость: {0}'}" />
                    <Label Text="{Binding Luck, StringFormat='Удача: {0}'}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Снаряжение -->
            <Label Text="Снаряжение" FontAttributes="Bold" HorizontalOptions="Center" />
            <Grid ColumnDefinitions="*, *, *" RowDefinitions="80, 80, 80" Spacing="5" HorizontalOptions="Center">
                <Frame Grid.Row="0" Grid.Column="0" BorderColor="Gray" Padding="5">
                    <Label Text="Голова" FontSize="10" HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>
                <Frame Grid.Row="0" Grid.Column="1" BorderColor="Gray" Padding="5">
                    <Label Text="Амулет" FontSize="10" HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>
                <Frame Grid.Row="0" Grid.Column="2" BorderColor="Gray" Padding="5">
                    <Label Text="Тело" FontSize="10" HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>

                <Frame Grid.Row="1" Grid.Column="0" BorderColor="Gray" Padding="5">
                    <Label Text="Оружие" FontSize="10" HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>
                <Frame Grid.Row="1" Grid.Column="1" BorderColor="Gray" Padding="5">
                    <Label Text="Щит" FontSize="10" HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>
                <Frame Grid.Row="1" Grid.Column="2" BorderColor="Gray" Padding="5">
                    <Label Text="Перчатки" FontSize="10" HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>

                <Frame Grid.Row="2" Grid.Column="0" BorderColor="Gray" Padding="5">
                    <Label Text="Кольцо" FontSize="10" HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>
                <Frame Grid.Row="2" Grid.Column="1" BorderColor="Gray" Padding="5">
                    <Label Text="Ноги" FontSize="10" HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>
                <Frame Grid.Row="2" Grid.Column="2" BorderColor="Gray" Padding="5">
                    <Label Text="Кольцо" FontSize="10" HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>
            </Grid>

            <Button Text="Обновить" Command="{Binding RefreshCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
