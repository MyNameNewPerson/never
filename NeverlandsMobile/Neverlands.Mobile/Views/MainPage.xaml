<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Neverlands.Mobile.ViewModels"
             x:Class="Neverlands.Mobile.Views.MainPage"
             x:DataType="vm:MainViewModel"
             Title="Neverlands Dashboard">
    <Grid RowDefinitions="Auto, *, Auto, Auto" Padding="10">
        <!-- Header HUD -->
        <Frame Grid.Row="0" Padding="10" Margin="0,0,0,10">
            <VerticalStackLayout Spacing="5">
                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="{Binding CharacterName}" FontSize="20" FontAttributes="Bold"/>
                    <Label Text="{Binding Level, StringFormat='[{0} уровень]'}" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <Grid ColumnDefinitions="40, *, 60" ColumnSpacing="5">
                    <Label Text="HP" VerticalOptions="Center"/>
                    <ProgressBar Grid.Column="1" Progress="{Binding HpPercent}" ProgressColor="Red" VerticalOptions="Center"/>
                    <Label Grid.Column="2" Text="{Binding HpStatus}" FontSize="12" HorizontalOptions="End" VerticalOptions="Center"/>
                </Grid>

                <Grid ColumnDefinitions="40, *, 60" ColumnSpacing="5">
                    <Label Text="MP" VerticalOptions="Center"/>
                    <ProgressBar Grid.Column="1" Progress="{Binding MpPercent}" ProgressColor="Blue" VerticalOptions="Center"/>
                    <Label Grid.Column="2" Text="{Binding MpStatus}" FontSize="12" HorizontalOptions="End" VerticalOptions="Center"/>
                </Grid>
            </VerticalStackLayout>
        </Frame>

        <!-- Main Content (Location & Event Log) -->
        <Grid Grid.Row="1" RowDefinitions="Auto, *">
            <Label Grid.Row="0" Text="{Binding CurrentLocation}" FontSize="18" HorizontalOptions="Center" Margin="0,5"/>
            <Frame Grid.Row="1" Padding="5" BorderColor="Gray">
                <ScrollView>
                    <Label Text="{Binding EventLogText}" FontSize="12" VerticalOptions="End"/>
                </ScrollView>
            </Frame>
        </Grid>

        <!-- Navigation Controls -->
        <Grid Grid.Row="2" HeightRequest="150" WidthRequest="150" HorizontalOptions="Center" Margin="0,10">
            <Button Text="N" Command="{Binding MoveNorthCommand}" HeightRequest="45" WidthRequest="45" VerticalOptions="Start" HorizontalOptions="Center"/>
            <Button Text="S" Command="{Binding MoveSouthCommand}" HeightRequest="45" WidthRequest="45" VerticalOptions="End" HorizontalOptions="Center"/>
            <Button Text="W" Command="{Binding MoveWestCommand}" HeightRequest="45" WidthRequest="45" VerticalOptions="Center" HorizontalOptions="Start"/>
            <Button Text="E" Command="{Binding MoveEastCommand}" HeightRequest="45" WidthRequest="45" VerticalOptions="Center" HorizontalOptions="End"/>
        </Grid>

        <!-- Footer Buttons -->
        <HorizontalStackLayout Grid.Row="3" HorizontalOptions="Center" Spacing="10" Margin="0,5">
            <Button Text="Карта" Command="{Binding OpenMapCommand}" WidthRequest="80"/>
            <Button Text="Персонаж" Command="{Binding OpenCharacterCommand}" WidthRequest="100"/>
            <Button Text="Бой" Command="{Binding ToggleAutomationCommand}"
                    WidthRequest="80">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsAutomationRunning}" Value="True">
                        <Setter Property="BackgroundColor" Value="Green" />
                    </DataTrigger>
                    <DataTrigger TargetType="Button" Binding="{Binding IsAutomationRunning}" Value="False">
                        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
