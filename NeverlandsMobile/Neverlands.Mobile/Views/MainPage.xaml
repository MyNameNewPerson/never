<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Neverlands.Mobile.ViewModels"
             x:Class="Neverlands.Mobile.Views.MainPage"
             x:DataType="vm:MainViewModel">
    <Grid RowDefinitions="Auto, Auto, *, Auto, Auto" Padding="10" Spacing="10">

        <!-- Шапка HUD -->
        <HorizontalStackLayout Grid.Row="0" Spacing="10" HorizontalOptions="Center">
            <Label Text="{Binding CharacterName}" FontSize="20" FontAttributes="Bold" />
            <Label Text="{Binding Level, StringFormat='[{0} уровень]'}" FontSize="18" VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!-- Статусы HP/MP -->
        <VerticalStackLayout Grid.Row="1" Spacing="5">
            <Grid ColumnDefinitions="*, Auto">
                <ProgressBar Progress="{Binding HpPercent}" ProgressColor="Red" HeightRequest="15" />
                <Label Grid.Column="1" Text="{Binding HpStatus}" Margin="10,0,0,0" VerticalOptions="Center" />
            </Grid>
            <Grid ColumnDefinitions="*, Auto">
                <ProgressBar Progress="{Binding MpPercent}" ProgressColor="Blue" HeightRequest="15" />
                <Label Grid.Column="1" Text="{Binding MpStatus}" Margin="10,0,0,0" VerticalOptions="Center" />
            </Grid>
            <Label Text="{Binding CurrentLocation}" HorizontalOptions="Center" FontAttributes="Italic" />
        </VerticalStackLayout>

        <!-- Лог событий -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding EventLog}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Label Text="{Binding .}" FontSize="12" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Кнопки движения и Статус автоматизации -->
        <Grid Grid.Row="3" ColumnDefinitions="*, *" Spacing="10">
            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding AutomationStatus}" HorizontalOptions="Center" />
                <Button Text="Вкл/Выкл Авто" Command="{Binding ToggleAutomationCommand}" FontSize="12" />
            </VerticalStackLayout>

            <Grid ColumnDefinitions="40, 40, 40" RowDefinitions="40, 40, 40" HorizontalOptions="Center">
                <Button Grid.Row="0" Grid.Column="1" Text="↑" Command="{Binding MoveNorthCommand}" Padding="0" />
                <Button Grid.Row="1" Grid.Column="0" Text="←" Command="{Binding MoveWestCommand}" Padding="0" />
                <Button Grid.Row="1" Grid.Column="2" Text="→" Command="{Binding MoveEastCommand}" Padding="0" />
                <Button Grid.Row="2" Grid.Column="1" Text="↓" Command="{Binding MoveSouthCommand}" Padding="0" />
            </Grid>
        </Grid>

        <!-- Навигация -->
        <FlexLayout Grid.Row="4" Wrap="Wrap" JustifyContent="SpaceAround" AlignItems="Center">
            <Button Text="Карта" Command="{Binding OpenMapCommand}" Margin="2" />
            <Button Text="Герой" Command="{Binding OpenCharacterCommand}" Margin="2" />
            <Button Text="Профили" Command="{Binding OpenProfilesCommand}" Margin="2" />
            <Button Text="Авто" Command="{Binding OpenAutomationCommand}" Margin="2" />
            <Button Text="Настройки" Command="{Binding OpenSettingsCommand}" Margin="2" />
        </FlexLayout>

    </Grid>
</ContentPage>
