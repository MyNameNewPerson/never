<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:Neverlands.Mobile.ViewModels"
             x:Class="Neverlands.Mobile.Views.MainPage"
             Title="Neverlands Dashboard">
    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
        <HorizontalStackLayout Grid.Row="0" Spacing="10">
            <Label Text="HP:" VerticalOptions="Center"/><ProgressBar Progress="{Binding State.CurrentHp}" WidthRequest="100"/>
            <Label Text="MP:" VerticalOptions="Center"/><ProgressBar Progress="{Binding State.CurrentMa}" WidthRequest="100" ProgressColor="Blue"/>
        </HorizontalStackLayout>
        <VerticalStackLayout Grid.Row="1" VerticalOptions="Center" Spacing="20">
            <Label Text="{Binding State.CurrentLocation}" FontSize="32" HorizontalOptions="Center"/>
            <Label Text="{Binding StatusMessage}" FontSize="18" HorizontalOptions="Center" TextColor="Gray"/>
            <Button Text="Start Auto-Combat" Command="{Binding StartAutomationCommand}"/>
            <Button Text="Stop" Command="{Binding StopAutomationCommand}" BackgroundColor="Red"/>
        </VerticalStackLayout>
        <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="20">
            <Button Text="Map"/><Button Text="Profiles"/><Button Text="Settings"/>
        </HorizontalStackLayout>
    </Grid>
</ContentPage>
